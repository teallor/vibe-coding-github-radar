{
  "name": "vibe-coding-github-radar",
  "version": "0.1.0",
  "description": "一个可调整需求画像的 GitHub 机会雷达，用于个人 Vibe Coding 学习、办公自动化、个人变现和新鲜有趣项目发现",
  "author": "Rafael_Huang",
  "license": "MIT",
  "scripts": {
    "start": "node workers/feishu-feedback-cloud-run.js",
    "scout": "node scripts/scout.js",
    "scout:local": "node scripts/scout.js",
    "podcast-radar": "node scripts/find-codex-podcasts.js",
    "ai-app-radar": "node scripts/ai-app-radar.js",
    "dry-run": "node scripts/radar-cli.js dry-run",
    "preview": "node scripts/radar-cli.js preview",
    "send-test": "node scripts/radar-cli.js send-test",
    "full-run": "node scripts/radar-cli.js full-run",
    "test": "node --test test/github-radar.test.js test/podcast-radar.test.js test/ai-app-radar.test.js test/daily-report.test.js test/schedule.test.js test/send-ledger.test.js test/focus-profiles.test.js && npm run test:feedback && npm run test:schedule && npm run test:feishu-feedback",
    "test:feedback": "node scripts/test-feedback-dedupe.js",
    "test:schedule": "node scripts/test-schedule-time.js",
    "test:feishu-feedback": "node scripts/test-feishu-feedback-worker.js && node scripts/test-feishu-feedback-cloud-run.js",
    "feedback": "node scripts/record-feedback.js"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5"
  },
  "keywords": [
    "vibe-coding",
    "github",
    "radar",
    "office-automation",
    "monetization",
    "codex",
    "open-source",
    "static-site",
    "github-pages",
    "pwa"
  ],
  "engines": {
    "node": ">=18"
  }
}
